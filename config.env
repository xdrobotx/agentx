# -----------------------------------------------------------------------------
# agentx - Local LLM Server Configuration
# -----------------------------------------------------------------------------

# The exact filename located inside your 'models/' directory
MODEL_FILE="qwen-3.6-35B-A3B-MTP-UD-IQ4_NL.gguf"

# llama.cpp server parameters
HOST="0.0.0.0"
PORT=9696
N_GPU_LAYERS=16
N_CPU_MOE=256
CTX_SIZE=131072
PREDICT=8192
BATCH_SIZE=16384
UBATCH_SIZE=1024
SPEC_TYPE="draft-mtp"
SPEC_DRAFT_MAX=1
PARALLEL=2
THREADS=8
TEMPERATURE="0.6"
TOP_P="0.95"
TOP_K=40
MIN_P="0.01"
REPEAT_PENALTY="1.0"
PRESENCE_PENALTY="0.0"
FREQUENCY_PENALTY="0.0"
REASONING="on"
REASONING_BUDGET=2048
CHAT_KWARGS='{"preserve_thinking": true}'
FIT="off"
FLASH_ATTN=1
CACHE_TYPE_K="iq4_nl"
CACHE_TYPE_V="iq4_nl"
SPLIT_MODE="layer"

# Compilation safety (Optional architecture pinning)
# 89 = Ada Lovelace (RTX 40xx), 86 = Ampere (RTX 30xx), 90 = Hopper
CUDA_ARCH=89
