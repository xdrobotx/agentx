# -----------------------------------------------------------------------------
# Pi Coding Agent Container
#
# Build:
#   podman build -t pi-agent -f Containerfile .
#
# Shared Podman Network:
#   podman network create agentx-network
# 
# Run:
#   podman run --rm -it \
#       --name pi-coding-agent \
#       --userns=keep-id \
#       --network agentx-network \
#       --read-only \
#       --tmpfs /tmp \
#       --mount type=tmpfs,destination=/home/pi,tmpfs-mode=0755 \
#       -v $(user-project):/workspace:Z \
#       -v $(agentx-repo)/containers/pi-agent/config:/home/pi/.pi/agent:Z \
#       pi-agent
#
# -----------------------------------------------------------------------------

# Use lightweight Node.js base image
FROM node:slim

# Environment Variables
ENV DEBIAN_FRONTEND=noninteractive
ENV NODE_ENV=production
ENV NPM_CONFIG_UPDATE_NOTIFIER=false

# Install System Dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
git \
    curl \
    wget \
    ca-certificates \
    procps \
    build-essential \
    python3 \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Create Non-Root User first to map directories correctly
RUN useradd -ms /bin/bash pi

# Set up non-root user home directory
ENV HOME=/home/pi
ENV WORKSPACE=/workspace

# Set up global npm directory for the non-root user
ENV NPM_CONFIG_PREFIX=${HOME}/.npm

ENV PATH="${NPM_CONFIG_PREFIX}/bin:${PATH}"

# Create config + workspace directories
RUN mkdir -p ${HOME}/.pi/agent \
    && mkdir -p ${NPM_CONFIG_PREFIX} \
    && mkdir -p ${WORKSPACE} \
    && chown -R pi:pi ${HOME} ${WORKSPACE}

# Switch to Non-Root User BEFORE installing global tools 
# so they reside safely in their home directory
USER pi

# Update npm and install tools inside the user space
RUN npm install -g npm@latest && \
    npm install -g @earendil-works/pi-coding-agent && \
    npm install -g gitnexus && \
    npm cache clean --force

WORKDIR ${WORKSPACE}

# Update Pi
RUN pi update

ENTRYPOINT ["pi"]
