# ==============================================================================
# agentx-pi
# ------------------------------------------------------------------------------
# Production-grade development container for:
#
#   - C / C++
#   - Rust
#   - Python
#   - Node.js tooling
#   - AI coding agents
#
# Features:
#
#   - Ubuntu 24.04 LTS
#   - Rootless runtime
#   - Immutable-friendly design
#   - Deterministic Node.js installation
#   - Minimal Rust toolchain
#   - Hardened runtime behavior
#   - Optimized build layers
#   - Tiny init process (tini)
#
# Build:
#
#   podman build -t agentx-pi .
#
# Recommended Run:
#
#   podman run --rm -it \
#       --name agentx-pi \
#       --userns=keep-id \
#       --network agentx-network \
#       --read-only \
#       --cap-drop=ALL \
#       --security-opt=no-new-privileges \
#       --tmpfs /tmp:rw,noexec,nosuid,size=512m \
#       --tmpfs /run:rw,nosuid,size=64m \
#       -v $(pwd):/workspace:Z \
#       -v $(pwd)/agent:/home/agentx/.pi/agent:Z \
#       agentx-pi
#
# ==============================================================================

FROM ubuntu:24.04

# ------------------------------------------------------------------------------
# Build Arguments
# ------------------------------------------------------------------------------

ARG NODE_VERSION=24.15.0
ARG RUST_TOOLCHAIN=stable

# ------------------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------------------

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=UTC \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    WORKSPACE=/workspace \
    CARGO_HOME=/opt/cargo \
    RUSTUP_HOME=/opt/rustup \
    NODE_PREFIX=/opt/node \
    PATH=/opt/cargo/bin:/opt/node/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/bin:/sbin

# ------------------------------------------------------------------------------
# Base System + Development Toolchains
# ------------------------------------------------------------------------------

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        bash \
        bash-completion \
        ca-certificates \
        curl \
        git \
        tini \
        build-essential \
        clang \
        lld \
        gdb \
        lldb \
        cmake \
        pkg-config \
        libssl-dev \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        ripgrep \
        fd-find \
        unzip \
        zip \
        xz-utils \
        less \
        nano && \
    rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------------------
# Node.js (Deterministic Binary Install)
# ------------------------------------------------------------------------------

RUN curl -fsSL \
        https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64.tar.xz \
    | tar -xJ -C /opt && \
    ln -s /opt/node-v${NODE_VERSION}-linux-x64 /opt/node && \
    ln -s /opt/node/bin/node /usr/local/bin/node && \
    ln -s /opt/node/bin/npm /usr/local/bin/npm && \
    ln -s /opt/node/bin/npx /usr/local/bin/npx && \
    node --version && \
    npm --version

# ------------------------------------------------------------------------------
# Rust Toolchain
# ------------------------------------------------------------------------------

RUN curl https://sh.rustup.rs -sSf | \
    bash -s -- \
        -y \
        --profile minimal \
        --default-toolchain ${RUST_TOOLCHAIN} && \
    rustup component add rustfmt clippy && \
    cargo install --locked cargo-binstall && \
    cargo --version && \
    rustc --version

# ------------------------------------------------------------------------------
# Global Node Tooling
# ------------------------------------------------------------------------------

# Pin versions for reproducible builds.
# Replace versions intentionally during upgrades.

RUN npm install -g \
        @earendil-works/pi-coding-agent@latest \
        gitnexus@latest && \
    npm cache clean --force

# ------------------------------------------------------------------------------
# Runtime User
# ------------------------------------------------------------------------------

RUN useradd \
        --create-home \
        --shell /bin/bash \
        agentx && \
    mkdir -p \
        /workspace \
        /home/agentx/.pi/agent && \
    chown -R agentx:agentx \
        /workspace \
        /home/agentx

# ------------------------------------------------------------------------------
# Final Cleanup
# ------------------------------------------------------------------------------

RUN apt-get autoremove -y && \
    apt-get clean && \
    rm -rf \
        /root/.cache \
        /root/.npm \
        /tmp/* \
        /var/tmp/*

# ------------------------------------------------------------------------------
# Runtime Configuration
# ------------------------------------------------------------------------------

USER agentx
WORKDIR /workspace

ARG PROMPT='export PS1="\[\033[35m\]\u\[\033[33m\]::\[\033[30m\]\h\[\033[35m\] : \[\033[33m\]\w $(__git_ps1 "\[\033[35m\](\[\033[36m\]%s\[\033[35m\])") \n\[\033[30m\]\$\[\033[00m\] "'

RUN touch /home/agentx/.bash_aliases

RUN echo ${PROMPT} >> /home/agentx/.bashrc
RUN echo 'alias cls="clear"' >> /home/agentx/.bash_aliases


# tini provides proper signal forwarding and zombie reaping.
ENTRYPOINT ["/usr/bin/tini", "--"]

CMD ["/bin/bash"]
